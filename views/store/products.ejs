<h1>Products Page</h1>
<div class="row">
  <% products.forEach(product => { %>
    <div class="box" style="display:flexs">
      <img src="<%= product.image %>" width="300px" alt="<%= product.name %>">
        <h2><%= product.name %></h2>
        <p><%= product.description %></p>
        <h4><%= product.price %></h4>
    </div>
  <% }) %>
</div>